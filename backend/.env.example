PORT=4000
NODE_ENV=development
SQLITE_PATH=./data/dealer.sqlite
NEON_DATABASE_URL=

# OpenAI
OPENAI_API_KEY=tu_api_key
OPENAI_MODEL=gpt-4o-mini
SYSTEM_PROMPT=Eres un asistente comercial experto en autos para un dealer. Tu objetivo es calificar leads, resolver dudas y guiar hacia cita o prueba de manejo.

# Twilio (opcional, recomendado en produccion)
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=false

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=dealer_verify_123
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v21.0
